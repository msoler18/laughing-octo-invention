# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role key — NEVER expose to the client/browser
# From: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anon/public key — safe to expose in the frontend
# From: Supabase Dashboard > Project Settings > API > anon key
SUPABASE_ANON_KEY=eyJ...

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Allowed origin for CORS (Next.js dev server)
CORS_ORIGIN=http://localhost:3000

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Used for: embeddings (text-embedding-3-small) and query parsing (gpt-4o-mini)
OPENAI_API_KEY=sk-...
