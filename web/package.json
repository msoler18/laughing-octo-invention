{
	"name": "realup-web",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"prepare": "cd .. && simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "cd web && npx biome check --no-errors-on-unmatched ."
	},
	"dependencies": {
		"next": "16.2.3",
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"simple-git-hooks": "^2.13.1",
		"tailwindcss": "^4",
		"typescript": "^5"
	}
}
